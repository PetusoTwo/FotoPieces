---
import puzzleGameScript from '../scripts/puzzle-game.js?url';
---

<section class="scrollbar-soft h-[100svh] w-screen overflow-y-auto overflow-x-hidden pb-3">
    <div class="">
        <div class="relative flex min-h-full min-h-0 flex-col p-3 md:p-4">
            <div class="pointer-events-none absolute -left-16 -top-14 h-44 w-44 rounded-full bg-[#ed254e]/30 blur-3xl">
            </div>
            <div
                class="pointer-events-none absolute -bottom-16 -right-10 h-44 w-44 rounded-full bg-[#f9dc5c]/35 blur-3xl">
            </div>

            <header class="relative z-10 flex shrink-0 items-start justify-between gap-3">
                <div class="min-w-0">
                    <p class="text-[10px] font-semibold uppercase tracking-[0.34em] text-slate-600 dark:text-slate-300">
                        FotoPieces</p>
                    <h1
                        class="font-[Sora] text-xl font-bold leading-tight text-slate-900 dark:text-slate-100 md:text-3xl">
                        Rompecabezas en vivo con tus fotos</h1>
                    <p class="mt-1 max-w-3xl text-xs text-slate-600 dark:text-slate-300 md:text-sm">
                        Sube una foto o capturala desde tu camara. Cada partida crea piezas con bordes aleatorios.
                    </p>
                    <a href="https://petusotwo.me" target="_blank" rel="noreferrer"
                        class="cursor-pointer mt-1 inline-block text-[11px] font-medium text-[#011936] underline decoration-dotted underline-offset-2 dark:text-[#f9dc5c]">
                        Hecho por PetusoTwo
                    </a>
                </div>
            </header>

            <div class="relative z-10 mt-3 grid min-h-0 flex-1 grid-cols-1 gap-3 lg:grid-cols-[minmax(220px,30vw)_minmax(0,1fr)]">
                <aside class="grid grid-rows-[auto_auto_auto] gap-3 lg:order-1 lg:min-h-0 lg:grid-rows-[auto_auto_1fr]">
                    <div class="glass-card rounded-2xl p-3">
                        <h2 class="font-[Sora] text-sm font-semibold text-slate-800 dark:text-slate-100 md:text-base">Tu
                            fuente de imagen</h2>
                        <div class="mt-2 grid gap-2">
                            <label class="block text-xs font-medium text-slate-700 dark:text-slate-200">Subir
                                foto</label>
                            <input id="image-input" type="file" accept="image/*" class="sr-only" />
                            <div class="flex min-w-0 items-center gap-2">
                                <label for="image-input"
                                    class="cursor-pointer rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:bg-slate-800">
                                    Elegir archivo
                                </label>
                                <span id="image-file-name"
                                    class="min-w-0 flex-1 truncate text-[11px] text-slate-500 dark:text-slate-300">
                                    Ningun archivo seleccionado
                                </span>
                            </div>

                            <div class="mt-1 flex flex-wrap gap-1.5">
                                <button id="start-camera" type="button"
                                    class="cursor-pointer rounded-xl bg-[#011936] px-2 py-1.5 text-xs font-medium text-white transition hover:bg-[#102c52]">Abrir
                                    camara</button>
                                <button id="mobile-camera-back" type="button"
                                    class="hidden cursor-pointer rounded-xl bg-[#011936] px-2 py-1.5 text-xs font-medium text-white transition hover:bg-[#102c52]">
                                    Tomar Foto
                                </button>
                                <button id="capture-photo" type="button"
                                    class="cursor-pointer rounded-xl bg-[#ed254e] px-2 py-1.5 text-xs font-medium text-white transition hover:bg-[#d42046]"
                                    disabled>Capturar</button>
                                <button id="stop-camera" type="button"
                                    class="cursor-pointer rounded-xl border border-slate-300 bg-white px-2 py-1.5 text-xs font-medium text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:bg-slate-800"
                                    disabled>Cerrar</button>
                            </div>

                            <input id="mobile-camera-input-back" type="file" accept="image/*" capture="environment" class="sr-only" />
                            <input id="mobile-camera-input-front" type="file" accept="image/*" capture="user" class="sr-only" />

                            <div id="camera-preview-wrap"
                                class="mt-1 overflow-hidden rounded-xl border border-slate-300 bg-slate-950/80 dark:border-slate-600">
                                <video id="camera-preview" class="h-24 w-full object-cover md:h-28" autoplay muted
                                    playsinline></video>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card rounded-2xl p-3">
                        <h2 class="font-[Sora] text-sm font-semibold text-slate-800 dark:text-slate-100 md:text-base">
                            Reglas del caos</h2>
                        <div class="mt-2 space-y-2 text-xs text-slate-700 dark:text-slate-200">
                            <label class="block">
                                <span class="mb-1 block font-medium">Dificultad</span>
                                <input id="grid-size" type="range" min="3" max="7" value="4"
                                    class="cursor-pointer w-full accent-[#ed254e]" />
                                <span id="grid-size-label"
                                    class="mt-1 block text-[11px] text-slate-500 dark:text-slate-300">4 x 4
                                    piezas</span>
                            </label>

                            <div class="grid grid-cols-2 gap-2 rounded-xl bg-white/70 p-2 dark:bg-slate-900/60">
                                <div>
                                    <p class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-300">
                                        Tiempo</p>
                                    <p id="timer" class="text-lg font-bold text-[#011936] dark:text-[#f9dc5c]">00:00</p>
                                </div>
                                <div>
                                    <p class="text-[10px] uppercase tracking-wide text-slate-500 dark:text-slate-300">
                                        Movimientos</p>
                                    <p id="moves" class="text-lg font-bold text-[#011936] dark:text-[#f9dc5c]">0</p>
                                </div>
                            </div>

                            <div class="flex flex-wrap gap-1.5">
                                <button id="shuffle-pieces" type="button"
                                    class="cursor-pointer rounded-xl bg-[#465362] px-2 py-1.5 text-xs font-medium text-white transition hover:bg-[#36404d]"
                                    disabled>Mezclar</button>
                                <button id="reset-game" type="button"
                                    class="cursor-pointer rounded-xl border border-slate-300 bg-white px-2 py-1.5 text-xs font-medium text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:bg-slate-800">Nueva
                                    foto</button>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card flex min-h-0 h-full flex-col overflow-hidden rounded-2xl p-3">
                        <h2 class="font-[Sora] text-sm font-semibold text-slate-800 dark:text-slate-100 md:text-base">
                            Tus puzzles recientes</h2>
                        <div id="history-list"
                            class="scrollbar-soft mt-2 grid min-h-0 flex-1 gap-2 overflow-y-auto overflow-x-hidden pr-1 text-xs text-slate-700 dark:text-slate-200">
                            <p class="text-xs text-slate-500 dark:text-slate-300">Todavia no resolviste puzzles D:</p>
                        </div>
                    </div>
                </aside>

                <div class="glass-card min-h-0 rounded-2xl p-3 md:p-4 lg:order-2">
                    <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
                        <p id="status-text" class="text-xs font-medium text-slate-700 dark:text-slate-200 md:text-sm">
                            Sube o captura una foto para comenzar.</p>
                        <p id="source-name"
                            class="max-w-[42%] truncate text-[10px] uppercase tracking-[0.18em] text-slate-500 dark:text-slate-300">
                        </p>
                    </div>

                    <div id="playfield" class="relative mx-auto flex w-full flex-col overflow-visible lg:h-full">
                        <div id="board"
                            class="relative mx-auto aspect-[16/10] w-full max-w-[96vw] overflow-hidden rounded-2xl border border-white/80 bg-white/70 dark:border-slate-600 dark:bg-slate-900/70 lg:max-w-[90vw]">
                            <div id="board-image" class="absolute inset-0 bg-contain bg-center bg-no-repeat opacity-25 transition">
                            </div>
                            <canvas id="board-overlay" class="absolute inset-0 h-full w-full"></canvas>
                            <div id="victory-banner"
                                class="pointer-events-none absolute inset-0 z-50 hidden items-center justify-center bg-[#011936]/85 p-6 text-center">
                                <div>
                                    <p class="font-[Sora] text-2xl font-bold text-[#f9dc5c] md:text-3xl">Puzzle completo
                                    </p>
                                    <p id="victory-summary" class="mt-2 text-xs text-slate-100 md:text-sm"></p>
                                </div>
                            </div>
                        </div>

                        <div id="tray"
                            class="relative mt-2 h-28 overflow-hidden rounded-2xl border border-white/70 bg-slate-100/70 dark:border-slate-600 dark:bg-slate-950/55 md:h-36">
                            <div
                                class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_18%,rgba(237,37,78,0.17),transparent_44%),radial-gradient(circle_at_88%_72%,rgba(1,25,54,0.24),transparent_48%)]">
                            </div>
                            <p
                                class="absolute left-3 top-2 text-[10px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-300">
                                Zona de mezcla</p>
                        </div>

                        <div id="pieces-layer" class="absolute inset-0"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script type="module" src={puzzleGameScript}></script>