---
import '../styles/global.css';

const { title = 'FotoPieces | Puzzle interactivo' } = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favic.png" />
		<link rel="icon" href="/favic.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Sora:wght@500;700&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="h-full antialiased">
		<slot />
	</body>
</html>
